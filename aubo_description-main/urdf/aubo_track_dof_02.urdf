    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file_path" />
      </geometry>
      <material name="">
        <color rgba="1 1 1 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file_path" />
      </geometry>
    </collision>
  </link>

  <joint name="motion_joint01" type="prismatic">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="movement_axis_Link01" />
    <axis xyz="0 0 0" />
    <limit lower="0.0" upper="0.0" effort="0.0" start_stop="0.0" velocity="0.0" />
    <property inertia="0" damping="0" stiffness="0" offset="0" motor_constant="0" ratio="0"/>
  </joint>
  
  <link name="movement_axis_Link02">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0" />
      <inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file_path" />
      </geometry>
      <material name="">
        <color rgba="1 1 1 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file_path" />
      </geometry>
    </collision>
  </link>

  <joint name="motion_joint02" type="prismatic">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="movement_axis_Link01" />
    <child link="movement_axis_Link02" />
